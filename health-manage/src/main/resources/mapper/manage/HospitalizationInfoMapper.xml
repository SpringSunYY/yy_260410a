<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lz.manage.mapper.HospitalizationInfoMapper">
    
    <resultMap type="HospitalizationInfo" id="HospitalizationInfoResult">
        <result property="id"    column="id"    />
        <result property="residentId"    column="resident_id"    />
        <result property="inTime"    column="in_time"    />
        <result property="outTime"    column="out_time"    />
        <result property="hospitalName"    column="hospital_name"    />
        <result property="hospitalReason"    column="hospital_reason"    />
        <result property="status"    column="status"    />
        <result property="appendix"    column="appendix"    />
        <result property="userId"    column="user_id"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectHospitalizationInfoVo">
        select id, resident_id, in_time, out_time, hospital_name, hospital_reason, status, appendix, user_id, create_by, create_time, update_by, update_time, remark from tb_hospitalization_info
    </sql>

    <select id="selectHospitalizationInfoList" parameterType="HospitalizationInfo" resultMap="HospitalizationInfoResult">
        <include refid="selectHospitalizationInfoVo"/>
        <where>  
            <if test="id != null "> and id = #{id}</if>
            <if test="residentId != null"> and resident_id = #{residentId}</if>
            <if test="params.beginInTime != null and params.beginInTime != '' and params.endInTime != null and params.endInTime != ''"> and DATE_FORMAT(in_time, '%Y-%m-%d') between #{params.beginInTime} and #{params.endInTime}</if>
            <if test="params.beginOutTime != null and params.beginOutTime != '' and params.endOutTime != null and params.endOutTime != ''"> and DATE_FORMAT(out_time, '%Y-%m-%d') between #{params.beginOutTime} and #{params.endOutTime}</if>
            <if test="hospitalName != null  and hospitalName != ''"> and hospital_name like concat('%', #{hospitalName}, '%')</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="createBy != null  and createBy != ''"> and create_by like concat('%', #{createBy}, '%')</if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != '' and params.endCreateTime != null and params.endCreateTime != ''"> and DATE_FORMAT(create_time, '%Y-%m-%d') between #{params.beginCreateTime} and #{params.endCreateTime}</if>
        </where>
    </select>
    
    <select id="selectHospitalizationInfoById" parameterType="Long" resultMap="HospitalizationInfoResult">
        <include refid="selectHospitalizationInfoVo"/>
        where id = #{id}
    </select>

    <insert id="insertHospitalizationInfo" parameterType="HospitalizationInfo" useGeneratedKeys="true" keyProperty="id">
        insert into tb_hospitalization_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="residentId != null">resident_id,</if>
            <if test="inTime != null">in_time,</if>
            <if test="outTime != null">out_time,</if>
            <if test="hospitalName != null and hospitalName != ''">hospital_name,</if>
            <if test="hospitalReason != null and hospitalReason != ''">hospital_reason,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="appendix != null">appendix,</if>
            <if test="userId != null">user_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="residentId != null">#{residentId},</if>
            <if test="inTime != null">#{inTime},</if>
            <if test="outTime != null">#{outTime},</if>
            <if test="hospitalName != null and hospitalName != ''">#{hospitalName},</if>
            <if test="hospitalReason != null and hospitalReason != ''">#{hospitalReason},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="appendix != null">#{appendix},</if>
            <if test="userId != null">#{userId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateHospitalizationInfo" parameterType="HospitalizationInfo">
        update tb_hospitalization_info
        <trim prefix="SET" suffixOverrides=",">
            <if test="residentId != null">resident_id = #{residentId},</if>
            <if test="inTime != null">in_time = #{inTime},</if>
            <if test="outTime != null">out_time = #{outTime},</if>
            <if test="hospitalName != null and hospitalName != ''">hospital_name = #{hospitalName},</if>
            <if test="hospitalReason != null and hospitalReason != ''">hospital_reason = #{hospitalReason},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="appendix != null">appendix = #{appendix},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="createBy != null and createBy != ''">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteHospitalizationInfoById" parameterType="Long">
        delete from tb_hospitalization_info where id = #{id}
    </delete>

    <delete id="deleteHospitalizationInfoByIds" parameterType="String">
        delete from tb_hospitalization_info where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>