<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lz.manage.mapper.ServiceAppointmentInfoMapper">
    
    <resultMap type="ServiceAppointmentInfo" id="ServiceAppointmentInfoResult">
        <result property="id"    column="id"    />
        <result property="residentId"    column="resident_id"    />
        <result property="serviceType"    column="service_type"    />
        <result property="contactMethod"    column="contact_method"    />
        <result property="appointmentTitle"    column="appointment_title"    />
        <result property="appointmentReason"    column="appointment_reason"    />
        <result property="appointmentTime"    column="appointment_time"    />
        <result property="dateType"    column="date_type"    />
        <result property="status"    column="status"    />
        <result property="appointmentUserId"    column="appointment_user_id"    />
        <result property="serviceTime"    column="service_time"    />
        <result property="appendix"    column="appendix"    />
        <result property="userId"    column="user_id"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectServiceAppointmentInfoVo">
        select id, resident_id, service_type, contact_method, appointment_title, appointment_reason, appointment_time, date_type, status, appointment_user_id, service_time, appendix, user_id, create_by, create_time, update_by, update_time, remark from tb_service_appointment_info
    </sql>

    <select id="selectServiceAppointmentInfoList" parameterType="ServiceAppointmentInfo" resultMap="ServiceAppointmentInfoResult">
        <include refid="selectServiceAppointmentInfoVo"/>
        <where>  
            <if test="id != null "> and id = #{id}</if>
            <if test="residentId != null"> and resident_id = #{residentId}</if>
            <if test="serviceType != null  and serviceType != ''"> and service_type = #{serviceType}</if>
            <if test="appointmentTitle != null  and appointmentTitle != ''"> and appointment_title like concat('%', #{appointmentTitle}, '%')</if>
            <if test="params.beginAppointmentTime != null and params.beginAppointmentTime != '' and params.endAppointmentTime != null and params.endAppointmentTime != ''"> and DATE_FORMAT(appointment_time, '%Y-%m-%d') between #{params.beginAppointmentTime} and #{params.endAppointmentTime}</if>
            <if test="dateType != null "> and date_type = #{dateType}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="appointmentUserId != null "> and appointment_user_id = #{appointmentUserId}</if>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="createBy != null  and createBy != ''"> and create_by like concat('%', #{createBy}, '%')</if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != '' and params.endCreateTime != null and params.endCreateTime != ''"> and DATE_FORMAT(create_time, '%Y-%m-%d') between #{params.beginCreateTime} and #{params.endCreateTime}</if>
        </where>
    </select>
    
    <select id="selectServiceAppointmentInfoById" parameterType="Long" resultMap="ServiceAppointmentInfoResult">
        <include refid="selectServiceAppointmentInfoVo"/>
        where id = #{id}
    </select>

    <insert id="insertServiceAppointmentInfo" parameterType="ServiceAppointmentInfo" useGeneratedKeys="true" keyProperty="id">
        insert into tb_service_appointment_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="residentId != null">resident_id,</if>
            <if test="serviceType != null and serviceType != ''">service_type,</if>
            <if test="contactMethod != null and contactMethod != ''">contact_method,</if>
            <if test="appointmentTitle != null and appointmentTitle != ''">appointment_title,</if>
            <if test="appointmentReason != null and appointmentReason != ''">appointment_reason,</if>
            <if test="appointmentTime != null">appointment_time,</if>
            <if test="dateType != null">date_type,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="appointmentUserId != null">appointment_user_id,</if>
            <if test="serviceTime != null">service_time,</if>
            <if test="appendix != null">appendix,</if>
            <if test="userId != null">user_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="residentId != null">#{residentId},</if>
            <if test="serviceType != null and serviceType != ''">#{serviceType},</if>
            <if test="contactMethod != null and contactMethod != ''">#{contactMethod},</if>
            <if test="appointmentTitle != null and appointmentTitle != ''">#{appointmentTitle},</if>
            <if test="appointmentReason != null and appointmentReason != ''">#{appointmentReason},</if>
            <if test="appointmentTime != null">#{appointmentTime},</if>
            <if test="dateType != null">#{dateType},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="appointmentUserId != null">#{appointmentUserId},</if>
            <if test="serviceTime != null">#{serviceTime},</if>
            <if test="appendix != null">#{appendix},</if>
            <if test="userId != null">#{userId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateServiceAppointmentInfo" parameterType="ServiceAppointmentInfo">
        update tb_service_appointment_info
        <trim prefix="SET" suffixOverrides=",">
            <if test="residentId != null">resident_id = #{residentId},</if>
            <if test="serviceType != null and serviceType != ''">service_type = #{serviceType},</if>
            <if test="contactMethod != null and contactMethod != ''">contact_method = #{contactMethod},</if>
            <if test="appointmentTitle != null and appointmentTitle != ''">appointment_title = #{appointmentTitle},</if>
            <if test="appointmentReason != null and appointmentReason != ''">appointment_reason = #{appointmentReason},</if>
            <if test="appointmentTime != null">appointment_time = #{appointmentTime},</if>
            <if test="dateType != null">date_type = #{dateType},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="appointmentUserId != null">appointment_user_id = #{appointmentUserId},</if>
            <if test="serviceTime != null">service_time = #{serviceTime},</if>
            <if test="appendix != null">appendix = #{appendix},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="createBy != null and createBy != ''">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteServiceAppointmentInfoById" parameterType="Long">
        delete from tb_service_appointment_info where id = #{id}
    </delete>

    <delete id="deleteServiceAppointmentInfoByIds" parameterType="String">
        delete from tb_service_appointment_info where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>