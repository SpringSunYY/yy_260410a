<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lz.manage.mapper.TreatmentInfoMapper">
    
    <resultMap type="TreatmentInfo" id="TreatmentInfoResult">
        <result property="id"    column="id"    />
        <result property="residentId"    column="resident_id"    />
        <result property="visitTime"    column="visit_time"    />
        <result property="diagnosis"    column="diagnosis"    />
        <result property="prescription"    column="prescription"    />
        <result property="appendix"    column="appendix"    />
        <result property="userId"    column="user_id"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectTreatmentInfoVo">
        select id, resident_id, visit_time, diagnosis, prescription, appendix, user_id, create_by, create_time, update_by, update_time, remark from tb_treatment_info
    </sql>

    <select id="selectTreatmentInfoList" parameterType="TreatmentInfo" resultMap="TreatmentInfoResult">
        <include refid="selectTreatmentInfoVo"/>
        <where>  
            <if test="id != null "> and id = #{id}</if>
            <if test="residentId != null"> and resident_id = #{residentId}</if>
            <if test="params.beginVisitTime != null and params.beginVisitTime != '' and params.endVisitTime != null and params.endVisitTime != ''"> and DATE_FORMAT(visit_time, '%Y-%m-%d') between #{params.beginVisitTime} and #{params.endVisitTime}</if>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="createBy != null  and createBy != ''"> and create_by like concat('%', #{createBy}, '%')</if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != '' and params.endCreateTime != null and params.endCreateTime != ''"> and DATE_FORMAT(create_time, '%Y-%m-%d') between #{params.beginCreateTime} and #{params.endCreateTime}</if>
        </where>
    </select>
    
    <select id="selectTreatmentInfoById" parameterType="Long" resultMap="TreatmentInfoResult">
        <include refid="selectTreatmentInfoVo"/>
        where id = #{id}
    </select>

    <insert id="insertTreatmentInfo" parameterType="TreatmentInfo" useGeneratedKeys="true" keyProperty="id">
        insert into tb_treatment_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="residentId != null">resident_id,</if>
            <if test="visitTime != null">visit_time,</if>
            <if test="diagnosis != null and diagnosis != ''">diagnosis,</if>
            <if test="prescription != null">prescription,</if>
            <if test="appendix != null">appendix,</if>
            <if test="userId != null">user_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="residentId != null">#{residentId},</if>
            <if test="visitTime != null">#{visitTime},</if>
            <if test="diagnosis != null and diagnosis != ''">#{diagnosis},</if>
            <if test="prescription != null">#{prescription},</if>
            <if test="appendix != null">#{appendix},</if>
            <if test="userId != null">#{userId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateTreatmentInfo" parameterType="TreatmentInfo">
        update tb_treatment_info
        <trim prefix="SET" suffixOverrides=",">
            <if test="residentId != null">resident_id = #{residentId},</if>
            <if test="visitTime != null">visit_time = #{visitTime},</if>
            <if test="diagnosis != null and diagnosis != ''">diagnosis = #{diagnosis},</if>
            <if test="prescription != null">prescription = #{prescription},</if>
            <if test="appendix != null">appendix = #{appendix},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="createBy != null and createBy != ''">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTreatmentInfoById" parameterType="Long">
        delete from tb_treatment_info where id = #{id}
    </delete>

    <delete id="deleteTreatmentInfoByIds" parameterType="String">
        delete from tb_treatment_info where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>