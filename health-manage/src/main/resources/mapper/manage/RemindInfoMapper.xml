<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lz.manage.mapper.RemindInfoMapper">
    
    <resultMap type="RemindInfo" id="RemindInfoResult">
        <result property="id"    column="id"    />
        <result property="reminderId"    column="reminder_id"    />
        <result property="residentId"    column="resident_id"    />
        <result property="reminderType"    column="reminder_type"    />
        <result property="reminderTitle"    column="reminder_title"    />
        <result property="reminderContent"    column="reminder_content"    />
        <result property="remindTime"    column="remind_time"    />
        <result property="readStatus"    column="read_status"    />
        <result property="readTime"    column="read_time"    />
        <result property="userId"    column="user_id"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectRemindInfoVo">
        select id, reminder_id, resident_id, reminder_type, reminder_title, reminder_content, remind_time, read_status, read_time, user_id, create_by, create_time, update_by, update_time, remark from tb_remind_info
    </sql>

    <select id="selectRemindInfoList" parameterType="RemindInfo" resultMap="RemindInfoResult">
        <include refid="selectRemindInfoVo"/>
        <where>  
            <if test="id != null "> and id = #{id}</if>
            <if test="reminderId != null "> and reminder_id = #{reminderId}</if>
            <if test="residentId != null "> and resident_id = #{residentId}</if>
            <if test="reminderType != null  and reminderType != ''"> and reminder_type = #{reminderType}</if>
            <if test="reminderTitle != null  and reminderTitle != ''"> and reminder_title = #{reminderTitle}</if>
            <if test="readStatus != null  and readStatus != ''"> and read_status = #{readStatus}</if>
            <if test="params.beginReadTime != null and params.beginReadTime != '' and params.endReadTime != null and params.endReadTime != ''"> and DATE_FORMAT(read_time, '%Y-%m-%d') between #{params.beginReadTime} and #{params.endReadTime}</if>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="createBy != null  and createBy != ''"> and create_by like concat('%', #{createBy}, '%')</if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != '' and params.endCreateTime != null and params.endCreateTime != ''"> and DATE_FORMAT(create_time, '%Y-%m-%d') between #{params.beginCreateTime} and #{params.endCreateTime}</if>
        </where>
    </select>
    
    <select id="selectRemindInfoById" parameterType="Long" resultMap="RemindInfoResult">
        <include refid="selectRemindInfoVo"/>
        where id = #{id}
    </select>

    <insert id="insertRemindInfo" parameterType="RemindInfo" useGeneratedKeys="true" keyProperty="id">
        insert into tb_remind_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="reminderId != null">reminder_id,</if>
            <if test="residentId != null">resident_id,</if>
            <if test="reminderType != null and reminderType != ''">reminder_type,</if>
            <if test="reminderTitle != null and reminderTitle != ''">reminder_title,</if>
            <if test="reminderContent != null and reminderContent != ''">reminder_content,</if>
            <if test="remindTime != null">remind_time,</if>
            <if test="readStatus != null and readStatus != ''">read_status,</if>
            <if test="readTime != null">read_time,</if>
            <if test="userId != null">user_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="reminderId != null">#{reminderId},</if>
            <if test="residentId != null">#{residentId},</if>
            <if test="reminderType != null and reminderType != ''">#{reminderType},</if>
            <if test="reminderTitle != null and reminderTitle != ''">#{reminderTitle},</if>
            <if test="reminderContent != null and reminderContent != ''">#{reminderContent},</if>
            <if test="remindTime != null">#{remindTime},</if>
            <if test="readStatus != null and readStatus != ''">#{readStatus},</if>
            <if test="readTime != null">#{readTime},</if>
            <if test="userId != null">#{userId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateRemindInfo" parameterType="RemindInfo">
        update tb_remind_info
        <trim prefix="SET" suffixOverrides=",">
            <if test="reminderId != null">reminder_id = #{reminderId},</if>
            <if test="residentId != null">resident_id = #{residentId},</if>
            <if test="reminderType != null and reminderType != ''">reminder_type = #{reminderType},</if>
            <if test="reminderTitle != null and reminderTitle != ''">reminder_title = #{reminderTitle},</if>
            <if test="reminderContent != null and reminderContent != ''">reminder_content = #{reminderContent},</if>
            <if test="remindTime != null">remind_time = #{remindTime},</if>
            <if test="readStatus != null and readStatus != ''">read_status = #{readStatus},</if>
            <if test="readTime != null">read_time = #{readTime},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="createBy != null and createBy != ''">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteRemindInfoById" parameterType="Long">
        delete from tb_remind_info where id = #{id}
    </delete>

    <delete id="deleteRemindInfoByIds" parameterType="String">
        delete from tb_remind_info where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>